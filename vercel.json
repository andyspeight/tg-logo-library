{
  "functions": {
    "api/discover.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/save.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/list.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/resolve-domain.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/list",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600" }
      ]
    },
    {
      "source": "/api/(discover|save|resolve-domain)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://logos.travelgenix.io" }
      ]
    }
  ]
}
