{
  "functions": {
    "api/discover.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/save.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/resolve-domain.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/bulk-suggest.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/bulk-process.js": {
      "memory": 1024,
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    }
  ]
}
