{
  "functions": {
    "api/discover.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/save.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/list.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/list-all.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/search.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/resolve-domain.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/list",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/search",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/(discover|save|resolve-domain|list-all)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
